# Copy to /etc/systemd/system/jarvis-ui.service
# Edit User, WorkingDirectory, and ExecStart paths to match your setup
[Unit]
Description=Jarvis UI
After=network.target

[Service]
Type=simple
# CHANGE THESE to match your user and install path:
User=YOURUSER
WorkingDirectory=/home/YOURUSER/jarvis-ui
ExecStart=/home/YOURUSER/jarvis-ui/venv/bin/uvicorn app:app --port 7000 --host 0.0.0.0
Restart=always
RestartSec=3
EnvironmentFile=-/home/YOURUSER/jarvis-ui/.env

[Install]
WantedBy=multi-user.target
