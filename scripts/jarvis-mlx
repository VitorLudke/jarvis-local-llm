#!/bin/zsh
# jarvis-mlx — Jarvis on Apple Silicon, one command.
#
# This is the script that makes Jarvis what it is on a Mac: it serves local
# models on the Metal GPU through Apple's MLX framework (mlx-lm / mlx-vlm)
# and puts the Jarvis workspace in front of them.
#
#   text model   mlx_lm.server     127.0.0.1:8081   Metal GPU, OpenAI-compatible
#   vision model mlx_vlm.server    127.0.0.1:8082   on demand only (see below)
#   chromadb     chroma run        127.0.0.1:8100   vector memory / RAG
#   frontend     start-macos.sh    127.0.0.1:7860   the Jarvis UI
#
# Usage:
#   jarvis-mlx               start text + chroma + frontend, open the browser
#   jarvis-mlx model         pick which model this Mac serves (saved choice)
#   jarvis-mlx vision        start the vision model on demand (port 8082)
#   jarvis-mlx vision stop   stop only the vision model (frees ~3 GB)
#   jarvis-mlx stop          stop everything
#   jarvis-mlx status        show what's running
#
# First run asks which model to serve — a short menu of mlx-community
# conversions (quantized for the Metal GPU on Apple Silicon), sized to this
# Mac's RAM, or any other mlx-community id you want. The choice is saved to
# data/mlx-launcher.conf; change it any time with `jarvis-mlx model`.
#
# The vision model does NOT start by default: an 8B text model + draft model
# + 4B vision model together can exhaust unified memory on a 16 GB Mac and
# trigger Metal GPU timeouts (kIOGPUCommandBufferCallbackErrorTimeout).
# Bring vision up only when you need it.
#
# Models are MLX-community conversions on Hugging Face, downloaded to the
# standard HF cache on first run. Env vars override the saved choice:
#   MLX_MODEL        any mlx-community id (skips the menu)
#   MLX_DRAFT_MODEL  default mlx-community/Qwen3-0.6B-4bit for Qwen3 models
#                    (speculative decoding, ~1.5x tokens/s; empty disables)
#   MLX_VL_MODEL     default mlx-community/Qwen3-VL-4B-Instruct-4bit
#   MLX_VENV         default <repo>/venv-mlx (created on first run)
#   MLX_PROMPT_CACHE_BYTES  default 2G — KV-cache ceiling for the text server.
#                    mlx_lm.server keeps every conversation's KV cache forever
#                    by default (~1.9GB per chat with Jarvis-sized prompts);
#                    unbounded, it OOMs the Metal GPU on 16GB Macs and the
#                    server dies with kIOGPUCommandBufferCallbackErrorOutOfMemory.
#                    Reusing a cached conversation deep-copies its KV (2x peak),
#                    so the ceiling must leave room for weights + 2x ceiling.
#   MLX_PREFILL_STEP default 512 — prefill chunk size in tokens. The default
#                    2048 packs long-prompt prefill into Metal command buffers
#                    big enough to trip the macOS GPU watchdog on 16GB Macs
#                    (kIOGPUCommandBufferCallbackErrorTimeout kills the server).

set -u

SCRIPT_DIR="${0:A:h}"
JARVIS_DIR="${JARVIS_DIR:-${SCRIPT_DIR:h}}"
MLX_VENV="${MLX_VENV:-$JARVIS_DIR/venv-mlx}"
MLX_CONF="$JARVIS_DIR/data/mlx-launcher.conf"
MLX_VL_MODEL="${MLX_VL_MODEL:-mlx-community/Qwen3-VL-4B-Instruct-4bit}"
MLX_PROMPT_CACHE_BYTES="${MLX_PROMPT_CACHE_BYTES:-2G}"
MLX_PREFILL_STEP="${MLX_PREFILL_STEP:-512}"
MLX_PORT=8081
MLX_VL_PORT=8082
CHROMA_PORT=8100
APP_PORT="${APP_PORT:-7860}"
LOG_DIR="${JARVIS_LOG_DIR:-$JARVIS_DIR/logs}"
mkdir -p "$LOG_DIR"

# Model choice resolution: explicit env > saved config > first-run menu > RAM default.
_ENV_MODEL="${MLX_MODEL:-}"
_ENV_DRAFT="${MLX_DRAFT_MODEL-__unset__}"   # unset != empty (empty disables draft)
[[ -f "$MLX_CONF" ]] && source "$MLX_CONF"
[[ -n "$_ENV_MODEL" ]] && MLX_MODEL="$_ENV_MODEL"
[[ "$_ENV_DRAFT" != "__unset__" ]] && MLX_DRAFT_MODEL="$_ENV_DRAFT"

port_pids() { lsof -ti :"$1" 2>/dev/null }

ram_gb() { echo $(( $(sysctl -n hw.memsize 2>/dev/null || echo 17179869184) / 1073741824 )) }

recommended_choice() {
  local ram=$(ram_gb)
  if   (( ram < 12 )); then echo 1
  elif (( ram < 24 )); then echo 2
  elif (( ram < 40 )); then echo 3
  else echo 4
  fi
}

model_for_choice() {
  case "$1" in
    1) echo "mlx-community/Qwen3-4B-4bit" ;;
    2) echo "mlx-community/Qwen3-8B-4bit" ;;
    3) echo "mlx-community/Qwen3-14B-4bit" ;;
    4) echo "mlx-community/Qwen3-30B-A3B-4bit" ;;
    *) echo "" ;;
  esac
}

default_draft_for() {
  # Speculative decoding needs a draft that shares the target's tokenizer —
  # only pair the Qwen3 0.6B draft with bigger Qwen3 targets.
  case "$1" in
    *Qwen3*0.6B*|*Qwen3-0.6B*) echo "" ;;
    *Qwen3*) echo "mlx-community/Qwen3-0.6B-4bit" ;;
    *) echo "" ;;
  esac
}

choose_model() {
  local ram=$(ram_gb) rec=$(recommended_choice) choice model
  echo ""
  echo "Which model should this Mac serve? (detected RAM: ${ram} GB)"
  echo "All options are mlx-community conversions — quantized for the Metal GPU"
  echo "on Apple Silicon, served natively by MLX."
  echo ""
  echo "  1) Qwen3-4B-4bit        ~2.3 GB weights   8 GB Macs"
  echo "  2) Qwen3-8B-4bit        ~4.4 GB weights   16 GB Macs"
  echo "  3) Qwen3-14B-4bit       ~7.9 GB weights   24 GB+ Macs"
  echo "  4) Qwen3-30B-A3B-4bit   ~16 GB weights    32 GB+ Macs (MoE, fast)"
  echo "  5) another mlx-community id (huggingface.co/mlx-community)"
  echo ""
  printf "Choice [%s]: " "$rec"
  read choice
  choice="${choice:-$rec}"
  if [[ "$choice" == 5 ]]; then
    printf "model id (e.g. mlx-community/gemma-3-12b-it-4bit): "
    read model
    [[ -z "$model" ]] && model=$(model_for_choice "$rec")
  else
    model=$(model_for_choice "$choice")
    [[ -z "$model" ]] && model=$(model_for_choice "$rec")
  fi
  local draft=$(default_draft_for "$model")
  mkdir -p "$JARVIS_DIR/data"
  {
    echo "# Written by jarvis-mlx — model choice. Change with: jarvis-mlx model"
    echo "MLX_MODEL=\"$model\""
    echo "MLX_DRAFT_MODEL=\"$draft\""
  } > "$MLX_CONF"
  MLX_MODEL="$model"
  MLX_DRAFT_MODEL="$draft"
  echo "Saved: $model${draft:+ (+ draft $draft)}"
}

ensure_mlx_venv() {
  if [[ ! -x "$MLX_VENV/bin/mlx_lm.server" ]]; then
    echo "Preparando venv MLX em $MLX_VENV (primeira vez, ~2 min)..."
    python3 -m venv "$MLX_VENV"
    "$MLX_VENV/bin/pip" install --quiet --upgrade pip mlx-lm mlx-vlm
  fi
}

wait_for_model() {
  local log="$LOG_DIR/mlx-server.log"
  echo "Waiting for $MLX_MODEL on port $MLX_PORT"
  echo "(first run downloads the weights to the Hugging Face cache — progress below)"
  local last="" stalled=0 i
  for i in {1..540}; do   # hard cap ~45 min (cold download on slow links)
    if curl -s -o /dev/null --max-time 2 "http://127.0.0.1:$MLX_PORT/v1/models"; then
      printf '\r%-92s\n' "Model ready."
      return 0
    fi
    if [[ -z "$(port_pids $MLX_PORT)" ]] && (( i > 3 )); then
      echo ""
      echo "O servidor do modelo morreu ao iniciar — veja $log"
      return 1
    fi
    local prog=$(tail -c 20000 "$log" 2>/dev/null | tr '\r' '\n' | grep -E '%\|' | tail -1 | cut -c1-90)
    if [[ -n "$prog" && "$prog" != "$last" ]]; then
      printf '\r  %-90s' "$prog"
      last="$prog"
      stalled=0
    else
      (( stalled += 1 ))
    fi
    if (( stalled > 60 )); then   # ~5 min without new output
      echo ""
      echo "Sem progresso há 5 min — veja $log"
      return 1
    fi
    sleep 5
  done
  echo ""
  echo "Modelo não respondeu — veja $log"
  return 1
}

case "${1:-start}" in
  stop)
    for port in $APP_PORT $MLX_PORT $MLX_VL_PORT $CHROMA_PORT; do
      pids=$(port_pids $port)
      if [[ -n "$pids" ]]; then
        echo "$pids" | xargs kill && echo "parado: porta $port (pid ${pids//$'\n'/, })"
      else
        echo "nada rodando na porta $port"
      fi
    done
    exit 0
    ;;
  status)
    [[ -n "$(port_pids $MLX_PORT)" ]] && echo "modelo:   ok (porta $MLX_PORT)" || echo "modelo:   parado"
    [[ -n "$(port_pids $MLX_VL_PORT)" ]] && echo "visão:    ok (porta $MLX_VL_PORT)" || echo "visão:    parada (sob demanda: jarvis-mlx vision)"
    [[ -n "$(port_pids $CHROMA_PORT)" ]] && echo "chroma:   ok (porta $CHROMA_PORT)" || echo "chroma:   parado"
    [[ -n "$(port_pids $APP_PORT)" ]] && echo "frontend: ok (porta $APP_PORT)" || echo "frontend: parado"
    exit 0
    ;;
  model)
    choose_model
    if [[ -n "$(port_pids $MLX_PORT)" ]]; then
      echo "Modelo atual ainda em execução — aplique a troca com: jarvis-mlx stop && jarvis-mlx"
    fi
    exit 0
    ;;
  vision)
    if [[ "${2:-}" == "stop" ]]; then
      pids=$(port_pids $MLX_VL_PORT)
      if [[ -n "$pids" ]]; then
        echo "$pids" | xargs kill && echo "visão parada (porta $MLX_VL_PORT)"
      else
        echo "visão já estava parada"
      fi
      exit 0
    fi
    if [[ -n "$(port_pids $MLX_VL_PORT)" ]]; then
      echo "Modelo de visão já rodando (porta $MLX_VL_PORT)"
      exit 0
    fi
    ensure_mlx_venv
    echo "Subindo modelo de visão $MLX_VL_MODEL na porta $MLX_VL_PORT..."
    nohup "$MLX_VENV/bin/python" -m mlx_vlm.server \
      --model "$MLX_VL_MODEL" --host 127.0.0.1 --port $MLX_VL_PORT \
      >> "$LOG_DIR/mlx-vl-server.log" 2>&1 &!
    printf "Aguardando visão"
    for i in {1..30}; do
      if curl -s -o /dev/null --max-time 2 "http://127.0.0.1:$MLX_VL_PORT/v1/models"; then
        echo " — pronta! Endpoint: http://127.0.0.1:$MLX_VL_PORT/v1"
        exit 0
      fi
      printf "."
      sleep 2
    done
    echo
    echo "Visão não respondeu em 60s — veja $LOG_DIR/mlx-vl-server.log"
    exit 1
    ;;
esac

# ---- start path ----

# No model picked yet (no env override, no saved config): ask on a terminal,
# fall back to the RAM-sized default when non-interactive.
if [[ -z "${MLX_MODEL:-}" ]]; then
  if [[ -t 0 ]]; then
    choose_model
  else
    MLX_MODEL=$(model_for_choice $(recommended_choice))
    MLX_DRAFT_MODEL=$(default_draft_for "$MLX_MODEL")
    echo "Sem terminal interativo — usando o padrão para esta RAM: $MLX_MODEL"
  fi
fi
# Draft never chosen explicitly (no env, no config line): pair by model family.
[[ "${MLX_DRAFT_MODEL-__unset__}" == "__unset__" ]] && MLX_DRAFT_MODEL=$(default_draft_for "$MLX_MODEL")

ensure_mlx_venv

if [[ -z "$(port_pids $MLX_PORT)" ]]; then
  echo "Subindo modelo $MLX_MODEL na porta $MLX_PORT..."
  draft_args=()
  [[ -n "$MLX_DRAFT_MODEL" ]] && draft_args=(--draft-model "$MLX_DRAFT_MODEL" --num-draft-tokens 3)
  # jarvis_mlx_server.py wraps mlx_lm.server: upstream only honors
  # --prompt-cache-bytes on the batched path, which a draft model disables.
  nohup "$MLX_VENV/bin/python" "$SCRIPT_DIR/jarvis_mlx_server.py" \
    --model "$MLX_MODEL" "${draft_args[@]}" \
    --prompt-cache-bytes "$MLX_PROMPT_CACHE_BYTES" \
    --prefill-step-size "$MLX_PREFILL_STEP" \
    --host 127.0.0.1 --port $MLX_PORT \
    >> "$LOG_DIR/mlx-server.log" 2>&1 &!
else
  echo "Modelo já rodando (porta $MLX_PORT)"
fi

if [[ -n "$(port_pids $MLX_VL_PORT)" ]]; then
  echo "Modelo de visão já rodando (porta $MLX_VL_PORT) — derrube com: jarvis-mlx vision stop"
else
  echo "Modelo de visão não sobe por padrão — quando precisar: jarvis-mlx vision"
fi

if [[ -z "$(port_pids $CHROMA_PORT)" ]]; then
  if [[ -x "$JARVIS_DIR/venv/bin/chroma" ]]; then
    echo "Subindo ChromaDB na porta $CHROMA_PORT..."
    nohup "$JARVIS_DIR/venv/bin/chroma" run --path "$JARVIS_DIR/data/chroma_server" \
      --host 127.0.0.1 --port $CHROMA_PORT >> "$LOG_DIR/chroma.log" 2>&1 &!
  else
    echo "ChromaDB pulado (venv do app ainda não existe — start-macos.sh cria)"
  fi
else
  echo "ChromaDB já rodando (porta $CHROMA_PORT)"
fi

# Remember where the app log ends now so we only surface *this boot's*
# first-run admin password, never one from an old log.
_APP_LOG_OFFSET=0
[[ -f "$LOG_DIR/app.log" ]] && _APP_LOG_OFFSET=$(wc -c < "$LOG_DIR/app.log" | tr -d ' ')

if [[ -z "$(port_pids $APP_PORT)" ]]; then
  echo "Subindo Jarvis na porta $APP_PORT..."
  # Seed the model picker on first boot: the app creates this endpoint when
  # no endpoint with the same base_url exists, so a fresh install needs no
  # manual Settings → Models step. Existing installs are left untouched.
  export JARVIS_SEED_MODEL_ENDPOINT="http://127.0.0.1:$MLX_PORT/v1"
  export JARVIS_SEED_MODEL_ENDPOINT_NAME="MLX local (Apple Silicon)"
  (cd "$JARVIS_DIR" && nohup ./start-macos.sh >> "$LOG_DIR/app.log" 2>&1 &!)
else
  echo "Jarvis já rodando (porta $APP_PORT)"
fi

printf "Aguardando frontend"
_FRONTEND_OK=0
for i in {1..60}; do
  if curl -s -o /dev/null --max-time 2 "http://127.0.0.1:$APP_PORT/login"; then
    echo " — pronto!"
    _FRONTEND_OK=1
    break
  fi
  printf "."
  sleep 2
done
if [[ "$_FRONTEND_OK" != 1 ]]; then
  echo
  echo "Frontend não respondeu em 120s — veja $LOG_DIR/app.log"
  exit 1
fi

# First boot creates the admin account and prints a temporary password — but
# under nohup that line lands in app.log where nobody sees it. Replay it here.
if [[ -f "$LOG_DIR/app.log" ]]; then
  _NEW_LOG=$(tail -c +"$(( _APP_LOG_OFFSET + 1 ))" "$LOG_DIR/app.log" 2>/dev/null)
  _PASS_LINE=$(echo "$_NEW_LOG" | grep -m1 'Temporary password:')
  if [[ -n "$_PASS_LINE" ]]; then
    _USER_LINE=$(echo "$_NEW_LOG" | grep -m1 -o 'admin user created ([^)]*)' | sed 's/.*(\(.*\))/\1/')
    echo ""
    echo "┌─ Primeiro acesso ─────────────────────────────────────────────"
    echo "│ usuário: ${_USER_LINE:-admin}"
    echo "│ senha temporária: ${_PASS_LINE##*: }"
    echo "│ Troque a senha depois do primeiro login (Settings → Account)."
    echo "└────────────────────────────────────────────────────────────────"
  fi
fi

wait_for_model || echo "A UI já está no ar em http://127.0.0.1:$APP_PORT — o modelo aparece no seletor quando ficar pronto."

open "http://127.0.0.1:$APP_PORT"
exit 0
